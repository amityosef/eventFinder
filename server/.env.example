# ===========================================
# Event Finder Server - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=http://localhost:5173

# Database - MongoDB
MONGODB_URI=mongodb://localhost:27017/eventfinder
MONGODB_DB_NAME=eventfinder

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=133007740031-hs48kk941n9v27hkjqjbvmmev2sc2h6k.apps.googleusercontent.com

# AWS S3 (for image uploads - optional, falls back to local storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=eventfinder-uploads

# Email - Nodemailer
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM="EventFinder" <noreply@eventfinder.com>

# AI Integration - OpenAI / Gemini
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
AI_PROVIDER=openai

# Elasticsearch (for logging)
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_INDEX=eventfinder-logs

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# SSL/HTTPS
SSL_KEY_PATH=../certs/server.key
SSL_CERT_PATH=../certs/server.crt

# Upload Settings
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
